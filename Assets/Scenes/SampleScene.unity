  m_text: "\u4E3B\u984C\u4E8C\u4ECB\u7D39\uFF1A\u667A\u6167\u74B0\u5883\u76E3\u63A7\u7CFB\u7D71\n\n\u900F\u904E\u6EAB\u6FD5\u5EA6\u611F\u6E2C\u5668\u6301\u7E8C\u76E3\u6E2C\u74B0\u5883\u72C0\u614B\uFF0C\u7576\u6578\u503C\u7570\u5E38\u6642\u81EA\u52D5\u767C\u51FA\u8B66\u5831\u901A\u77E5\u3002\n\n\u3010\u4F60\u5C07\u8A2D\u8A08\u7684\u7CFB\u7D71\u3011\n\u7576\u6EAB\u5EA6\u904E\u9AD8\u6642
    \u2192 \u81EA\u52D5\u555F\u52D5\u98A8\u6247\u6563\u71B1\r\n\u7576\u6FD5\u5EA6\u904E\u4F4E\u6642
    \u2192 \u767C\u51FA\u63D0\u9192\u8A0A\u865F\n\n\u3010\u6703\u7528\u5230\u7684\u5143\u4EF6\u3011\r\n\u2022
    \u6EAB\u6FD5\u5EA6\u611F\u6E2C\u5668\uFF08\u5075\u6E2C\u74B0\u5883\uFF09\r\n\u2022
    \u8702\u9CF4\u5668\uFF08\u8F38\u51FA\u8B66\u5831\uFF09\r\n\u2022 Webduino \u958B\u767C\u677F\n\n\u7269\u806F\u7DB2\u8B93\u88DD\u7F6E\u96A8\u6642\u300C\u611F\u77E5\u300D\u74B0\u5883\uFF0C\u66FF\u6211\u5011\u5B88\u8B77\u751F\u6D3B\u7A7A\u9593\u7684\u8212\u9069\u8207\u5B89\u5168\uFF01"
