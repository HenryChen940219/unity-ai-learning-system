  arduinoIntroductions:
  - "\u958B\u59CB Arduino \u8AB2\u7A0B\uFF01\u52D5\u624B\u524D\u5148\u5B78\u7FD2\u5DE5\u7A0B\u5E2B\u601D\u7DAD\uFF0C\u5B8C\u6210\u5C08\u6848\u8A2D\u8A08\u5716\u3002"
  - "Arduino \u5C31\u50CF\u5C0F\u5927\u8166\uFF0C\u5C08\u9580\u7528\u4F86\u63A7\u5236\u5404\u5F0F\u5404\u6A23\u7684\u771F\u5BE6\u96FB\u5B50\u96F6\u4EF6\uFF01"
  - "\u8A8D\u8B58 I/O\uFF01\u8F38\u5165\u8CA0\u8CAC\u611F\u53D7\u5916\u754C\u74B0\u5883\uFF0C\u8F38\u51FA\u5247\u7528\u4F86\u57F7\u884C\u5BE6\u969B\u52D5\u4F5C\u3002"
  - "\u6578\u4F4D\u8A0A\u865F\u5C31\u50CF\u96FB\u71C8\u958B\u95DC\uFF0C\u7279\u5FB5\u662F\u975E\u9ED1\u5373\u767D\uFF0C\u53EA\u6709\u958B\u8207\u95DC\u5169\u7A2E\u72C0\u614B\uFF01"
  - "\u985E\u6BD4\u8A0A\u865F\u5C31\u50CF\u97F3\u91CF\u65CB\u9215\uFF0C\u80FD\u9023\u7E8C\u8B8A\u5316\uFF0C\u4E26\u8B80\u53D6
    0 \u5230 1023 \u7684\u6578\u503C\u3002"
  - "\u7B2C\u4E00\u6B65\u62C6\u89E3\u554F\u984C\uFF01\u628A\u5C08\u6848\u5927\u554F\u984C\uFF0C\u5207\u5206\u6210\u8F38\u5165\u3001\u8F38\u51FA\u548C\u689D\u4EF6\u898F\u5247\u3002"
  - "\u7B2C\u4E8C\u6B65\u6A23\u5F0F\u8FA8\u8B58\uFF01\u6839\u64DA\u525B\u624D\u7684\u62BD\u8C61\u9700\u6C42\uFF0C\u627E\u51FA\u9069\u5408\u7684\u5BE6\u9AD4\u96FB\u5B50\u96F6\u4EF6\u3002"
  - "\u8A8D\u8B58\u9EB5\u5305\u677F\uFF01\u9019\u662F\u514D\u92B2\u63A5\u7684\u7D44\u88DD\u57FA\u5730\uFF0C\u8ACB\u52D9\u5FC5\u641E\u61C2\u5B83\u7684\u5C0E\u96FB\u65B9\u5411"
  - "\u5169\u5074\u76F4\u6392\u662F\u96FB\u6E90\u5C08\u7528\u9053\uFF01\u7D05\u7DDA\u63A55V\u6B63\u6975\uFF0C\u85CD\u7DDA\u63A5GND\u8CA0\u6975\u3002"
  - "\u4E2D\u9593\u6A6B\u6392\u7528\u4F86\u63D2\u96F6\u4EF6\uFF01\u8A18\u4F4F\uFF0C\u540C\u4E00\u6392\u7684\u4E94\u500B\u5C0F\u6D1E\u662F\u5DE6\u53F3\u76F8\u901A\u7684"
  - "\u5371\u96AA\u8B66\u544A\uFF01\u5343\u842C\u5225\u628A 5V \u6B63\u6975\u8207
    GND \u8CA0\u6975\u76F8\u9023\uFF0C\u6703\u9020\u6210\u77ED\u8DEF\u71D2\u6BC0\u6676\u7247"
  - "\u7B2C\u4E09\u6B65\u62BD\u8C61\u5316\uFF01\u8A18\u4F4F\u5C08\u6848\u56DB\u6B65\u9A5F\uFF1A\u63A5\u7DDA\u3001\u5BEB\u7A0B\u5F0F\u3001\u7DE8\u8B6F\u4E0A\u50B3\uFF0C\u6700\u5F8C\u662F\u9664\u932F"
  - "\u8F38\u5165\u63A5\u7DDA\uFF01\u8ACB\u8A8D\u660E\u4E09\u689D\u7DDA\uFF1AVCC
    \u63A5 5V\u3001GND \u63A5\u63A5\u5730\u3001\u8A0A\u865F\u7DDA\u63A5\u63A7\u5236\u8173\u4F4D\u3002"
  - "\u8F38\u51FA\u63A5\u7DDA\uFF01LED \u9577\u8173\u63A5\u8A0A\u865F\uFF0C\u77ED\u8173\u52D9\u5FC5\u4E32\u806F\u96FB\u963B\u518D\u63A5\u5730\uFF0C\u624D\u4E0D\u6703\u71D2\u58DE"
  - "\u6700\u5F8C\u662F\u7DE8\u8B6F\u4E0A\u50B3\uFF01\u96FB\u8166\u6703\u628A\u7A0B\u5F0F\u8B8A\u6210\u4E8C\u9032\u4F4D\u78BC\uFF0C\u900F\u904E\u50B3\u8F38\u7DDA\u71D2\u9304\u5230\u6676\u7247\u4E2D\u3002"
  - "\u9032\u5165\u6F14\u7B97\u6CD5\uFF01\u7528\u300E\u5982\u679C\u3001\u5C31\u300F\u7684\u689D\u4EF6\u908F\u8F2F\uFF0C\u5BEB\u51FA\u89E3\u6C7A\u554F\u984C\u7684\u6B65\u9A5F\u3002"
  - "\u7A0B\u5F0F\u96D9\u6838\u5FC3\uFF1Asetup\u505A\u8A2D\u5B9A\u53EA\u8DD1\u4E00\u6B21\uFF0Cloop\u6703\u7121\u9650\u5FAA\u74B0\u57F7\u884C\uFF01"
  - "\u8B8A\u6578\u5C31\u50CF\u8A18\u61B6\u76D2\u5B50\uFF0C\u80FD\u7528\u4F86\u5B58\u653E\u611F\u6E2C\u5668\u8B80\u53D6\u5230\u7684\u6574\u6578\u6216\u5C0F\u6578"
  - "\u9664\u932F\u5FC5\u5099\uFF01\u5E8F\u5217\u57E0\u76E3\u63A7\u80FD\u5C07\u611F\u6E2C\u5668\u7684\u6578\u5B57\uFF0C\u5373\u6642\u50B3\u56DE\u96FB\u8166\u87A2\u5E55\u986F\u793A\u3002"
  - "\u8A8D\u8B58 PWM\uFF01\u5229\u7528\u5FEB\u901F\u958B\u95DC\u6B3A\u9A19\u773C\u775B\uFF0C\u505A\u51FA\u71C8\u5149\u6F38\u4EAE\u6F38\u6697\u7684\u6548\u679C"
  - "\u6309\u9215\u5F48\u8DF3\uFF01\u91D1\u5C6C\u63A5\u89F8\u6703\u7522\u751F\u96DC\u8A0A\uFF0C\u8A18\u5F97\u8981\u7528\u7A0B\u5F0F\u904E\u6FFE\u51FA\u771F\u5BE6\u8A0A\u865F"
