  - {fileID: 21300000, guid: d6b0aec2d22af44438501ee0390948dd, type: 3}
  slideIntroductions:
  - "\u5148\u5E36\u5927\u5BB6\u8A8D\u8B58\u4ECA\u5929\u7684\u4E3B\u89D2\uFF1AWebduino\u958B\u767C\u677F\u8207\u7269\u806F\u7DB2\u3002"
  - "\u96FB\u5B50\u4E16\u754C\u5206\u70BA\u63A5\u6536\u611F\u89BA\u7684\u8F38\u5165\uFF0C\u4EE5\u53CA\u8CA0\u8CAC\u52D5\u4F5C\u7684\u8F38\u51FA\u88DD\u7F6E"
  - "\u6578\u4F4D\u8A0A\u865F\u6700\u7C21\u55AE\uFF01\u5B83\u7684\u7279\u5FB5\u662F\u975E\u9ED1\u5373\u767D\uFF0C\u53EA\u6709\u958B\u8207\u95DC\u5169\u7A2E\u72C0\u614B\u3002"
  - "\u985E\u6BD4\u8A0A\u865F\u662F\u9023\u7E8C\u8B8A\u5316\u7684\uFF0C\u5C31\u50CF\u6EAB\u5EA6\u9AD8\u4F4E\uFF0C\u6703\u6709\u4E00\u6BB5\u7BC4\u570D\u7684\u6578\u503C"
  - "\u52D5\u624B\u524D\u5148\u52D5\u8166\uFF01\u7528\u9019\u56DB\u500B\u904B\u7B97\u601D\u7DAD\u6B65\u9A5F\uFF0C\u4E00\u8D77\u5B8C\u6210\u5B78\u7FD2\u55AE\u898F\u5283\uFF01"
  - "\u628A\u5927\u554F\u984C\u62C6\u6210\uFF1A\u8F38\u5165\u8CC7\u6599\u3001\u8F38\u51FA\u53CD\u61C9\u8207\u904B\u4F5C\u898F\u5247\u4E09\u500B\u5C0F\u5340\u584A\uFF01"
  - "\u6839\u64DA\u4F60\u7684\u9700\u6C42\uFF0C\u5F9E\u96F6\u4EF6\u5EAB\u4E2D\u627E\u51FA\u5C0D\u61C9\u529F\u80FD\u7684\u611F\u6E2C\u5668\u89E3\u6CD5\uFF01"
  - "\u9019\u662F\u5927\u8166\uFF01\u900F\u904EWi-Fi\u9023\u7DB2\uFF0C\u5C31\u80FD\u7528\u7DB2\u9801\u7A4D\u6728\u63A7\u5236\u5B83\uFF01"
  - "\u9019\u662F\u514D\u710A\u63A5\u7684\u7D44\u88DD\u57FA\u5730\uFF01\u8981\u641E\u61C2\u5C0E\u96FB\u65B9\u5411\uFF0C\u96FB\u8DEF\u624D\u6703\u901A"
  - "\u7D05\u7DDA\u63A5VCC\u6B63\u6975\uFF0C\u85CD\u7DDA\u63A5GND\u8CA0\u6975\uFF0C\u5169\u5074\u76F4\u6392\u662F\u96FB\u6E90\u5C08\u7528\u9053"
  - "\u4E2D\u9593\u7528\u4F86\u63D2\u96F6\u4EF6\uFF0C\u6CE8\u610F\u540C\u4E00\u6A6B\u6392\u7684\u4E94\u500B\u6D1E\u662F\u5DE6\u53F3\u76F8\u901A\u7684\u3002"
  - "\u7D55\u5C0D\u7981\u6B62\uFF01\u6B63\u6975\u7D55\u5C0D\u4E0D\u80FD\u76F4\u63A5\u63A5\u8CA0\u6975\uFF0C\u5426\u5247\u6703\u767C\u751F\u77ED\u8DEF\u71D2\u6BC0\uFF01"
  - "\u62BD\u8C61\u5316\u5C31\u662F\u627E\u51FA\u898F\u5247\uFF01\u6BCF\u500B\u5C08\u6848\u90FD\u8981\u7167\u8457\uFF1A\u7DB2\u8DEF\u3001\u7D44\u88DD\u3001\u7A0B\u5F0F\u3001\u6E2C\u8A66\uFF01"
  - "\u7269\u806F\u7DB2\u7684\u7B2C\u4E00\u6B65\uFF01\u5FC5\u9808\u5148\u8A2D\u5B9A\u597D
    Wi-Fi \u5E33\u865F\u5BC6\u78BC\u624D\u80FD\u9023\u7DDA"
  - "\u611F\u6E2C\u5668\u6709\u4E09\u689D\u7DDA\uFF0C\u6B63\u6975\u3001\u8CA0\u6975\u8DDF\u8A0A\u865F\u7DDA\uFF0C\u770B\u6E05\u695A\u6A19\u793A\u518D\u63D2\uFF01"
  - "\u50CF LED \u71C8\u9019\u7A2E\u8F38\u51FA\u88DD\u7F6E\u6703\u5206\u9577\u77ED\u8173\uFF01\u9577\u8173\u63A5\u8A0A\u865F\uFF0C\u77ED\u8173\u63A5
    GND"
  - "\u756B\u51FA\u6D41\u7A0B\u5716\uFF01\u4ED4\u7D30\u60F3\u60F3\uFF1A\u300E\u5982\u679C\u300F\u767C\u751F\u4EC0\u9EBC\u4E8B\uFF0C\u300E\u5C31\u300F\u505A\u51FA\u4EC0\u9EBC\u53CD\u61C9\uFF1F"
  - "\u958B\u59CB\u62FC\u7A4D\u6728\u5566\uFF01\u8A18\u5F97\u6AA2\u67E5\u7A4D\u6728\u4E0A\u7684\u8173\u4F4D\u7DE8\u865F\uFF0C\u8981\u8DDF\u9EB5\u5305\u677F\u63D2\u7684\u4E00\u6A21\u4E00\u6A23\u3002"
  - "\u7A0B\u5F0F\u4E0D\u52D5\u600E\u9EBC\u8FA6\uFF1F\u8DDF\u8457\u9019\u56DB\u6B65\u7576\u5075\u63A2\uFF1A\u67E5\u7DB2\u8DEF\u3001\u67E5ID\u3001\u67E5\u63A5\u7DDA\u3001\u67E5\u6B63\u8CA0\u6975\uFF01"
  - "\u63A5\u4E0B\u4F86\u662F\u9032\u968E\u89C0\u5FF5\u7684\u5C0F\u88DC\u5145\uFF0C\u6578\u4F4D\u8173\u4F4D\u600E\u9EBC\u63A7\u5236\u4EAE\u5EA6\uFF1F\u7B54\u6848\u662F\u900F\u904E\u300E\u5FEB\u901F\u958B\u95DC\u300F\u7684PWM\u6280\u8853\uFF01"
  - "\u50CF\u8759\u8760\u4E00\u6A23\uFF01\u767C\u5C04\u8072\u6CE2\u518D\u63A5\u6536\u53CD\u5F48\uFF0C\u7528\u300E\u4F86\u56DE\u6642\u9593\u300F\u5C31\u80FD\u7CBE\u6E96\u7B97\u51FA\u8DDD\u96E2\uFF01"
  - "\u5C31\u50CF\u8ABF\u8272\u76E4\uFF01\u8ABF\u6574\u7D05\u3001\u7DA0\u3001\u85CD\u4E09\u500B\u5149\u67F1\u7684\u5F37\u5F31\uFF0C\u5C31\u80FD\u6DF7\u51FA\u5404\u7A2E\u984F\u8272"
  - "\u8CC7\u6599\u7684\u65C5\u884C\uFF01\u5F9E\u611F\u6E2C\u5668\u5230\u958B\u767C\u677F\uFF0C\u900F\u904EWi-Fi\u4E0A\u96F2\u7AEF\uFF0C\u6700\u5F8C\u986F\u793A\u5728\u96FB\u8166\u4E0A\u3002"
  - "\u7A0B\u5F0F\u4E0D\u662F\u53EA\u8DD1\u4E00\u6B21\uFF01\u5B83\u6709\u500B\u300E\u76E3\u807D\u8005\u300F\u6703\u4E0D\u65B7\u6AA2\u67E5\u5404\u7A2E\u689D\u4EF6\u6709\u6C92\u6709\u767C\u751F\u3002"
  - "\u6309\u9215\u6309\u4E00\u4E0B\u537B\u8B80\u5230\u597D\u5E7E\u6B21\uFF1F\u9019\u662F\u91D1\u5C6C\u63A5\u89F8\u6642\u7684\u5F48\u8DF3\u96DC\u8A0A\uFF0C\u9700\u8981\u7A0B\u5F0F\u8655\u7406"
  - "\u9019\u5C31\u662F\u81EA\u52D5\u5316\uFF01\u6EAB\u5EA6\u4E0A\u5347\u7576\u8F38\u5165\uFF0C\u96F2\u7AEF\u5224\u65B7\u5F8C\uFF0C\u555F\u52D5\u98A8\u6247\u7576\u8F38\u51FA\uFF01"
  - "\u5148\u5099\u77E5\u8B58\u90FD\u5B78\u6703\u56C9\uFF01\u73FE\u5728\u6E96\u5099\u597D\u5B78\u7FD2\u55AE\uFF0C\u9EDE\u64CAGO\u6309\u9215\uFF0C\u6211\u5011\u6E96\u5099\u958B\u59CB\uFF01"
  webduinoHintSprites:
