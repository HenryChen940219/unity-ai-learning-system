  m_text: "\u78BA\u8A8D\u96FB\u8166\u9023\u7DDA\uFF1A\u8981\u628A\u5927\u8166 (\u7A0B\u5F0F)
    \u88DD\u9032\u81EA\u8D70\u8ECA\u88E1\uFF0C\u5FC5\u9808\u78BA\u4FDD Arduino \u548C\u96FB\u8166\u9023\u4E0A\u7DDA\u3002\n\u958B\u767C\u677F\u7684
    USB \u7DDA\u6709\u6C92\u6709\u78BA\u5BE6\u63D2\u597D\uFF1F\u677F\u5B50\u4E0A\u7684\u96FB\u6E90\u71C8\u6709\u4EAE\u55CE\uFF1F\n\u5728\u5BEB\u7A0B\u5F0F\u7684\u8EDF\u9AD4\u4E2D\uFF0C\u6709\u6C92\u6709\u9078\u5C0D\u5C0D\u61C9\u7684\u300C\u5E8F\u5217\u57E0
    (COM Port)\u300D\uFF1F\n\n\u9019\u5169\u500B\u90FD\u78BA\u8A8D\u6C92\u554F\u984C\u7684\u8A71\uFF0C\u5C31\u5B8C\u6210\u9023\u7DDA\u6E96\u5099\u56C9\uFF01"
