    \uFF08\u60F3\u60F3\u770B\u71C8\u7684\u72C0\u614B\u6709\u54EA\u5E7E\u7A2E\uFF1F\uFF09\r\n\r\n3.
    \u4EC0\u9EBC\u60C5\u6CC1\u4E0B\u624D\u9700\u8981\u89F8\u767C\u9019\u500B\u53CD\u61C9\uFF1F\r\n  
    \uFF08\u767D\u5929\u8DDF\u665A\u4E0A\u6709\u4EC0\u9EBC\u4E0D\u540C\uFF1F\uFF09\r\n\r\n\u60F3\u597D\u4E86\u5C31\u586B\u9032\u5B78\u7FD2\u55AE\uFF0C\r\n\u518D\u9EDE\u64CA\u300CAR
    \u5C55\u793A\u52D5\u756B\u300D\u89C0\u770B\u793A\u7BC4\uFF01"
  - "\u7FFB\u7FFB\u96F6\u4EF6\u5EAB\u601D\u8003\u770B\u770B\uFF1A\n\r\n1. \u8981\u5075\u6E2C\u5149\u7DDA\u5F37\u5F31\uFF0C\u4F60\u6703\u9078\u54EA\u500B\u611F\u6E2C\u5668\uFF1F\r\n\r\n2.
    \u8981\u8B93\u71C8\u767C\u5149\uFF0C\u4F60\u6703\u9078\u54EA\u500B\u4F5C\u52D5\u5668\uFF1F\r\n\r\n3.
    \u5149\u7DDA\u7684\u5F37\u5F31\u662F\u300C\u53EA\u6709\u5169\u7A2E\u72C0\u614B\u300D\r\n  
    \u9084\u662F\u300C\u9023\u7E8C\u8B8A\u5316\u7684\u6578\u503C\u300D\uFF1F\r\n  
    \u2192 \u5C0D\u61C9\u6578\u4F4D\u9084\u662F\u985E\u6BD4\u8A0A\u865F\uFF1F\r\n\r\n\u9078\u597D\u5F8C\u586B\u9032\u5B78\u7FD2\u55AE\uFF0C\r\n\u518D\u9EDE\u64CA\u300CAR
    \u5C55\u793A\u52D5\u756B\u300D\u89C0\u770B\u793A\u7BC4\uFF01"
  - "1. SOP \u56DB\u500B\u6B65\u9A5F\u4F60\u90FD\u77E5\u9053\u8981\u505A\u4EC0\u9EBC\u55CE\uFF1F\r\n  
    \u4F9D\u5E8F\u5B8C\u6210\u4E26\u6253\u52FE \r\n\r\n2. \u63A5\u7DDA\u8173\u4F4D\u8981\u586B\u4EC0\u9EBC\uFF1F\n  
    \u63D0\u793A\uFF1A\r\r\n   - \u5149\u654F\u96FB\u963B\u662F\u985E\u6BD4\u8A0A\u865F\uFF0C\u5EFA\u8B70\u63A5
    A0\uFF08A \u958B\u982D\u5C08\u7D66\u985E\u6BD4\uFF09\u3002\r\n   - LED \u662F\u6578\u4F4D\uFF0C0~13
    \u4EFB\u4E00\u865F\u90FD\u53EF\u4EE5\uFF0C\u5EFA\u8B70\u63A5 10 \u865F\uFF0C\u524D\u5F8C\u8981\u4E00\u81F4\u5594\uFF01\r\r\n\r\n\u586B\u5B8C\u5F8C\u9EDE\u300CAR
    \u5C55\u793A\u52D5\u756B\u300D\r\n\u770B\u770B\u771F\u5BE6\u7684\u63A5\u7DDA\u65B9\u5F0F\uFF01"
  - "\u5B8C\u6210\u9019\u500B\u908F\u8F2F\u9020\u53E5\uFF1A\r\n\u5982\u679C\uFF08___\uFF09\uFF0C\r\n\u5C31\uFF08___\uFF09\uFF1B\r\n\u5426\u5247\uFF08___\uFF09\u3002\r\n\r\n\u63D0\u793A\uFF1A\r\n-
    \u300C\u5982\u679C\u300D\u8981\u586B\u4E00\u500B\u5224\u65B7\u689D\u4EF6\r\n-
    \u5149\u7DDA\u591A\u6697\u624D\u7B97\u300C\u4E0D\u5920\u4EAE\u300D\uFF1F\u9019\u500B\u9580\u6ABB\u6578\u503C\u4F60\u4F86\u8A2D\u5B9A\uFF01\r\n-
    \u689D\u4EF6\u6210\u7ACB\u6216\u4E0D\u6210\u7ACB\uFF0C\u71C8\u5206\u5225\u600E\u6A23\uFF1F\r\n\r\n\u586B\u5B8C\u9EDE\u64CA\u300CAR
    \u5C55\u793A\u52D5\u756B\u300D\u5C0D\u7167\uFF01"
  - "\u60F3\u4E00\u60F3\uFF1A\r\n1. \u4F60\u7684\u7CFB\u7D71\u8981\u611F\u77E5\u54EA\u4E9B\u74B0\u5883\u6578\u64DA\uFF1F\n 
    \uFF08\u60F3\u60F3\u4EC0\u9EBC\u6578\u503C\u80FD\u53CD\u6620\u74B0\u5883\u72C0\u6CC1\uFF09\r\n\r\n2.
    \u6578\u503C\u7570\u5E38\u6642\uFF0C\u88DD\u7F6E\u8981\u505A\u4EC0\u9EBC\u8B66\u793A\uFF1F\r\n\r\n3.
    \u591A\u5C11\u6578\u503C\u624D\u7B97\u300C\u7570\u5E38\u300D\u9700\u8981\u8B66\u5831\uFF1F\r\n 
    \uFF08\u592A\u71B1\uFF1F\u591A\u5C11\u5EA6\uFF1F\u4F60\u4F86\u6C7A\u5B9A\uFF01\uFF09\r\n\r\n\u60F3\u597D\u518D\u586B\uFF0C\u9EDE\u300CAR
    \u5C55\u793A\u52D5\u756B\u300D\u5C0D\u7167\uFF01"
  - "\u7FFB\u7FFB\u96F6\u4EF6\u5EAB\uFF1A\r\n1. \u8981\u540C\u6642\u5075\u6E2C\u6EAB\u5EA6\u548C\u6FD5\u5EA6\uFF0C\u9078\u54EA\u7A2E\u611F\u6E2C\u5668\uFF1F\r\n\r\n2.
    \u8981\u767C\u51FA\u8B66\u5831\u8072\uFF0C\u9078\u54EA\u500B\u4F5C\u52D5\u5668\uFF1F\r\n\r\n3.
    \u6EAB\u5EA6\u6578\u503C\u662F\u300C\u53EA\u6709\u5169\u7A2E\u72C0\u614B\u300D\u9084\u662F\u300C\u9023\u7E8C\u8B8A\u5316\u7684\u6578\u503C\u300D\uFF1F\r\n 
    \u2192 \u5C0D\u61C9\u54EA\u7A2E\u8A0A\u865F\u985E\u578B\uFF1F\r\n\r\n\u9078\u597D\u586B\u5165\uFF0C\u9EDE\u300CAR
    \u5C55\u793A\u52D5\u756B\u300D\uFF01"
  - "1. SOP \u56DB\u6B65\u9A5F\u4F9D\u5E8F\u6253\u52FE \r\n\r\n2. \u63A5\u7DDA\u8173\u4F4D\u600E\u9EBC\u586B\uFF1F\r\n 
    \u6EAB\u6FD5\u5EA6\u611F\u6E2C\u5668\u662F\u6578\u4F4D\u8A0A\u865F\uFF0C\r\n 
    \u5EFA\u8B70\u63A5 11 \u865F\u8173\u4F4D\u3002\r\n  \u8702\u9CF4\u5668\u4E5F\u662F\u6578\u4F4D\uFF0C\r\n 
    \u5EFA\u8B70\u63A5 10 \u865F\uFF0C\u4F46\u5176\u5BE6 0~13 \u90FD\u53EF\u4EE5\u5594\uFF01\r\n\r\n\u586B\u597D\u5F8C\u9EDE\u300CAR
    \u5C55\u793A\u52D5\u756B\u300D\r\n\u770B\u770B\u771F\u5BE6\u63A5\u7DDA\u9577\u4EC0\u9EBC\u6A23\uFF01"
  - "\u5B8C\u6210\u9019\u500B\u908F\u8F2F\u9020\u53E5\uFF1A\r\n\u5982\u679C\uFF08___\uFF09\uFF0C\r\n\u5C31\uFF08___\uFF09\uFF1B\r\n\u5426\u5247\uFF08___\uFF09\u3002\r\n\r\n\u63D0\u793A\uFF1A\r\n-
    \u5E7E\u5EA6\u4EE5\u4E0A\u624D\u7B97\u904E\u71B1\u9700\u8981\u8B66\u5831\uFF1F\u9019\u500B\u9580\u6ABB\u503C\u4F60\u4F86\u8A2D\u5B9A\uFF01\r\n-
    \u8B66\u5831\u555F\u52D5\u6642\uFF0C\u8702\u9CF4\u5668\u8981\u505A\u4EC0\u9EBC\uFF1F\r\n-
    \u6EAB\u5EA6\u6B63\u5E38\u6642\uFF0C\u7CFB\u7D71\u53C8\u8A72\u5982\u4F55\uFF1F\r\n\r\n\u586B\u5B8C\u9EDE\u300CAR
    \u5C55\u793A\u52D5\u756B\u300D\u5C0D\u7167\uFF01"
  - "\u770B\u770B\u5B78\u7FD2\u55AE\u7684\u300C1. \u62C6\u89E3\u554F\u984C\u300D\r\n\r\n\u60F3\u4E00\u60F3\uFF1A\r\n1.
    \u9632\u76DC\u7CFB\u7D71\u8981\u300C\u611F\u77E5\u300D\u4EC0\u9EBC\uFF1F\r\n 
    \uFF08\u600E\u9EBC\u77E5\u9053\u6709\u4EBA\u5728\u9760\u8FD1\uFF1F\uFF09\r\n\r\n2.
    \u5075\u6E2C\u5230\u7570\u5E38\u5F8C\uFF0C\u7CFB\u7D71\u8981\u505A\u4EC0\u9EBC\uFF1F\r\n 
    \uFF08\u8072\u97F3\uFF1F\u71C8\u5149\uFF1F\u9084\u662F\u5169\u500B\u90FD\u8981\uFF1F\uFF09\r\n\r\n3.
    \u591A\u8FD1\u624D\u7B97\u300C\u6709\u4EBA\u5165\u4FB5\u300D\uFF1F\r\n  \u4F60\u89BA\u5F97\u5408\u7406\u7684\u8DDD\u96E2\u662F\u591A\u5C11\uFF1F\r\n\r\n\u60F3\u597D\u518D\u586B\uFF0C\u9EDE\u300CAR
    \u5C55\u793A\u52D5\u756B\u300D\u5C0D\u7167\uFF01"
  - "\u7FFB\u7FFB\u96F6\u4EF6\u5EAB\uFF1A\r\n1. \u8981\u5075\u6E2C\u7269\u9AD4\u9760\u8FD1\u7684\u8DDD\u96E2\uFF0C\r\n 
    \u9078\u54EA\u7A2E\u611F\u6E2C\u5668\uFF1F\r\n\r\n2. \u8981\u540C\u6642\u767C\u51FA\u8072\u97F3\u548C\u71C8\u5149\u8B66\u793A\uFF0C\r\n 
    \u9700\u8981\u9078\u5E7E\u500B\u4F5C\u52D5\u5668\uFF1F\r\n\r\n3. \u300C\u6709\u4EBA\u300D\u6216\u300C\u6C92\u4EBA\u300D\u9019\u7A2E\u5224\u65B7\uFF0C\r\n 
    \u5C6C\u65BC\u54EA\u7A2E\u8A0A\u865F\u985E\u578B\uFF1F\r\n\r\n\u9078\u597D\u586B\u5165\uFF0C\u9EDE\u300CAR
    \u5C55\u793A\u52D5\u756B\u300D\uFF01"
  - "SOP \u56DB\u6B65\u9A5F\u4F9D\u5E8F\u6253\u52FE \r\n\r\n- \u63A5\u7DDA\u8173\u4F4D\u600E\u9EBC\u586B\uFF1F\r\n 
    \u8D85\u97F3\u6CE2\u6709\u5169\u689D\u8A0A\u865F\u7DDA\uFF0C\u5EFA\u8B70 Trig
    \u63A5 13 \u865F\u3001Echo \u63A5 12 \u865F\u3002\r\n  \u8702\u9CF4\u5668\u5EFA\u8B70\u63A5
    10 \u865F\uFF0C\r\n  LED \u5EFA\u8B70\u63A5 11 \u865F\u3002\r\n  \u6578\u4F4D\u8173\u4F4D
    0~13 \u5176\u5BE6\u90FD\u53EF\u4EE5\u5594\uFF01\r\n\r\n\u586B\u597D\u5F8C\u9EDE\u300CAR
    \u5C55\u793A\u52D5\u756B\u300D\r\n\u770B\u770B\u771F\u5BE6\u63A5\u7DDA\u9577\u4EC0\u9EBC\u6A23\uFF01"
  - "\u5B8C\u6210\u9019\u500B\u908F\u8F2F\u9020\u53E5\uFF1A\r\n\u5982\u679C\uFF08___\uFF09\uFF0C\r\n\u5C31\uFF08___\uFF09\uFF1B\r\n\u5426\u5247\uFF08___\uFF09\u3002\r\n\r\n\u63D0\u793A\uFF1A\r\n-
    \u5E7E\u516C\u5206\u4EE5\u5167\u7B97\u300C\u592A\u8FD1\u300D\u8981\u8B66\u5831\uFF1F\u9019\u500B\u8DDD\u96E2\u9580\u6ABB\u4F60\u4F86\u8A2D\u5B9A\uFF01\r\n-
    \u8B66\u5831\u89F8\u767C\u6642\uFF0C\u8702\u9CF4\u5668\u548C LED \u540C\u6642\u8981\u505A\u4EC0\u9EBC\uFF1F\r\n-
    \u6C92\u6709\u4EBA\u9760\u8FD1\u6642\uFF0C\u7CFB\u7D71\u61C9\u8A72\u600E\u6A23\uFF1F\r\n\r\n\u586B\u5B8C\u9EDE\u300CAR
    \u5C55\u793A\u52D5\u756B\u300D\u5C0D\u7167\uFF01"
