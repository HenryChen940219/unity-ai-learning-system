  m_text: "\u7D66\u96F6\u4EF6\u4E00\u500B\u300C\u5730\u5740\u300D\uFF1A\u96FB\u8166\u4E0D\u77E5\u9053\u8D85\u97F3\u6CE2\u9577\u4EC0\u9EBC\u6A23\u5B50\uFF0C\u53EA\u77E5\u9053\u5B83\u63D2\u5728\u54EA\u500B\u8173\u4F4D\uFF01\n\u8D85\u97F3\u6CE2\u611F\u6E2C\u5668
