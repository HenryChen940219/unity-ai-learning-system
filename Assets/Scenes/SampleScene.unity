  m_text: "\u5B89\u5168\u7B2C\u4E00\uFF1A \u70BA\u4E86\u4E0D\u8981\u8B8A\u6210\u707D\u96E3\uFF0C\u63A5\u7DDA\u7D55\u5C0D\u4E0D\u80FD\u932F\uFF01
